\begin_inset Formula $U_{n}$
\end_inset

,
 apply the KC theorem to 
\begin_inset Formula $\{(\sigma_{2n,k},\abs{\sigma_{2n,k}}-n)\}_{n,k\in\N}$
\end_inset

.
\end_layout

\begin_deeper
\begin_layout Itemize
Bound:
 
\begin_inset Formula $\sum_{k,n}2^{n-\abs{\sigma_{2n,k}}}\leq\sum_{n}2^{n}\mu(U_{2n})\leq\sum2^{-n}=1$
\end_inset

.
\end_layout

\begin_layout Itemize
Conclusion:
 For any 
\begin_inset Formula $b_{0}$
\end_inset

,
 we know 
\begin_inset Formula $X\in U_{2b_{0}}$
\end_inset

,
 and so there exists some 
\begin_inset Formula $\sigma_{2b_{0},k}$
\end_inset

