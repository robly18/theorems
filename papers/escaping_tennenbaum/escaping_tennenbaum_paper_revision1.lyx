\end_layout

\begin_layout Itemize
\begin_inset Formula $w^{n+1}(\alpha,mA,A,S^{0}A,S^{1}A,\dots,S^{n}A,S^{n+1}A)=w^{n}(\alpha,(S^{n+1}A,mA),A,S^{0}A,\dots,S^{n}A)$
